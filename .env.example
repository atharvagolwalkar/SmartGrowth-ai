# SmartGrowth AI Environment Configuration
# Copy this file to .env and customize for your environment

# Application Environment
ENVIRONMENT=development
PROJECT_NAME=SmartGrowth AI
VERSION=1.0.0
DEBUG=true

# Database Configuration
DATABASE_DB_PATH=smartgrowth.db
DATABASE_CONNECTION_TIMEOUT=30

# ML Model Configuration
ML_MODEL_PATH=ml_models/churn/enhanced_churn_model.joblib
ML_DEFAULT_THRESHOLD=0.5
ML_BATCH_SIZE=100
ML_MODEL_CACHE_TTL=3600

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_RELOAD=true
API_LOG_LEVEL=info
API_CORS_ORIGINS=["*"]

# Dashboard Configuration
DASHBOARD_HOST=localhost
DASHBOARD_PORT=8501
DASHBOARD_API_BASE_URL=http://localhost:8000
DASHBOARD_PAGE_TITLE=SmartGrowth AI Dashboard

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s"
LOG_FILE_PATH=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Production overrides (uncomment for production deployment)
# ENVIRONMENT=production
# DEBUG=false
# API_DEBUG=false
# API_RELOAD=false
# API_CORS_ORIGINS=["https://yourdomain.com"]
# LOG_LEVEL=WARNING
# LOG_FILE_PATH=logs/smartgrowth.log